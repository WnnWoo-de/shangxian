# API 地址
# Pages 前后端同项目部署时保持为空，默认使用同域 /api
# 当前自定义域名：https://www.wsbs.wnnw.fun/
# 线上会自动请求：https://www.wsbs.wnnw.fun/api
# 只有后端单独部署到其他域名时才填写
# 示例：VITE_API_BASE_URL=https://api.example.com/api
VITE_API_BASE_URL=

# 可选：主服务异常时的兜底后端
# 同项目部署一般不需要填写
# 示例：VITE_FALLBACK_API_BASE_URL=https://backup-api.example.com/api
VITE_FALLBACK_API_BASE_URL=

# 可选：同步接口专用兜底地址（当 /sync/* 返回 404 时自动切换）
# 同项目部署一般不需要填写
# 示例：VITE_SYNC_API_FALLBACK_URL=https://backup-api.example.com/api
VITE_SYNC_API_FALLBACK_URL=

# 可选：请求超时时间（毫秒）
# 示例：VITE_API_TIMEOUT=20000
VITE_API_TIMEOUT=

# 可选：弱网自适应超时时间上限（毫秒）
# 示例：VITE_API_MAX_TIMEOUT=60000
VITE_API_MAX_TIMEOUT=

# 可选：GET 请求弱网重试次数
# 示例：VITE_API_GET_RETRY_COUNT=2
VITE_API_GET_RETRY_COUNT=

# 可选：GET 请求重试基础退避（毫秒）
# 示例：VITE_API_RETRY_BASE_DELAY=600
VITE_API_RETRY_BASE_DELAY=

# 可选：相同错误提示的最小间隔（毫秒）
# 示例：VITE_API_ERROR_TOAST_COOLDOWN=8000
VITE_API_ERROR_TOAST_COOLDOWN=

# 可选：是否启用演示数据自动回填（默认关闭，生产建议保持关闭）
# 示例：VITE_ENABLE_DEMO_SEED=1
VITE_ENABLE_DEMO_SEED=
