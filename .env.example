# 独立后端地址（Worker）
# 示例：VITE_API_BASE_URL=https://my-cloudflare-backend.<your-subdomain>.workers.dev/api
VITE_API_BASE_URL=

# 可选：主服务异常时的兜底后端
# 示例：VITE_FALLBACK_API_BASE_URL=https://backup-backend.<your-subdomain>.workers.dev/api
VITE_FALLBACK_API_BASE_URL=

# 可选：请求超时时间（毫秒）
# 示例：VITE_API_TIMEOUT=20000
VITE_API_TIMEOUT=

# 可选：弱网自适应超时时间上限（毫秒）
# 示例：VITE_API_MAX_TIMEOUT=60000
VITE_API_MAX_TIMEOUT=

# 可选：GET 请求弱网重试次数
# 示例：VITE_API_GET_RETRY_COUNT=2
VITE_API_GET_RETRY_COUNT=

# 可选：GET 请求重试基础退避（毫秒）
# 示例：VITE_API_RETRY_BASE_DELAY=600
VITE_API_RETRY_BASE_DELAY=

# 可选：相同错误提示的最小间隔（毫秒）
# 示例：VITE_API_ERROR_TOAST_COOLDOWN=8000
VITE_API_ERROR_TOAST_COOLDOWN=
